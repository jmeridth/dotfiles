[user]
  name = jmeridth
  email = jmeridth@gmail.com
  signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIMqx3i3GOjjPQAOf4VXQewDvd+I1Woycv6+XW1AlHycG
[github]
  user = jmeridth
[color]
  ui = true
[color "branch"]
  current = yellow black
  local = yellow
  remote = magenta
[color "status"]
  added = yellow
  changed = green
  untracked = cyan
  branch = magenta
[commit]
  gpgsign = true
[tag]
  gpgsign = true
[alias]
  gl = pull -r --prune
  gs = status -sb
[grep]
  lineNumber = true
[fetch]
  prune = true
[rerere]
  enabled = true
[push]
  default = current
[pull]
  rebase = true
[help]
  autocorrect = 1
[branch]
  autosetuprebase = always
[core]
  editor = vim
  whitespace = cr-at-eol
  autocrlf = false
  commentChar = "@"
  excludesfile = ~/.gitignore
  pager = less -F -X
[remote]
  pushdefault = origin
[filter "lfs"]
  clean = git-lfs clean -- %f
  smudge = git-lfs smudge --skip -- %f
  process = git-lfs filter-process --skip
  required = true
[init]
  defaultBranch = main
[url "git@github.com:"]
  insteadOf = https://github.com/
[diff]
  ignoreSubmodules = dirty
[gpg]
  format = ssh
[gpg "ssh"]
  program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign
[include]
  path = ~/.gitconfig.local
[credential "https://github.com"]
	helper = 
	helper = !/usr/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/usr/bin/gh auth git-credential
